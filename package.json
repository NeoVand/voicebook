{
	"name": "voicebook",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"preview:pages": "node scripts/serve-pages.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:unit:run": "vitest --run",
		"test:coverage": "vitest --run --coverage",
		"test": "npm run test:unit:run && npm run test:e2e",
		"test:e2e": "playwright test",
		"quality": "npm run lint && npm run check && npm run test:coverage && npm run build"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@eslint/js": "^10.0.1",
		"@napi-rs/canvas": "1.0.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/katex": "^0.16.7",
		"@types/node": "^26",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-v8": "4.1.10",
		"@webgpu/types": "0.1.71",
		"docx": "9.7.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"fake-indexeddb": "6.2.5",
		"globals": "^17.6.0",
		"linkedom": "0.18.13",
		"mdsvex": "^0.12.7",
		"onnxruntime-common": "^1.27.0",
		"pdf-lib": "1.17.1",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	},
	"dependencies": {
		"@fontsource-variable/instrument-sans": "5.2.8",
		"@fontsource-variable/newsreader": "5.2.10",
		"@huggingface/hub": "^2.13.3",
		"@lucide/svelte": "1.24.0",
		"@mediabunny/mp3-encoder": "1.50.8",
		"@soundtouchjs/audio-worklet": "2.1.0",
		"highlight.js": "^11.11.1",
		"idb": "8.0.3",
		"katex": "^0.16.22",
		"mammoth": "1.11.0",
		"mediabunny": "1.50.8",
		"mermaid": "^11.16.0",
		"onnxruntime-web-supertone": "npm:onnxruntime-web@1.23.0",
		"pdfjs-dist": "5.4.624",
		"remark-definition-list": "^2.0.0",
		"remark-gfm": "4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "11.0.0",
		"unified": "11.0.5"
	}
}
